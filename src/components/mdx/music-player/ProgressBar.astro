---
/**
 * ProgressBar - 进度条组件
 * 显示播放进度并支持点击/拖动跳转
 */

export interface Props {
  progress: number;      // 0-100
  currentTime: number;   // 秒
  duration: number;      // 秒
  className?: string;
}

const { 
  progress = 0, 
  currentTime = 0, 
  duration = 0,
  className = '' 
} = Astro.props;
---

<div class={`progress-bar-container ${className}`}>
  <div class="progress-bar-wrapper">
    <div class="progress-bar-track">
      <div 
        class="progress-bar-fill" 
        style={`width: ${Math.min(100, Math.max(0, progress))}%`}
      >
        <div class="progress-bar-thumb"></div>
      </div>
    </div>
  </div>
  
  <div class="progress-bar-time">
    <span class="time-current" data-time={currentTime}></span>
    <span class="time-separator">/</span>
    <span class="time-duration" data-time={duration}></span>
  </div>
</div>

<script>
  import { formatTime } from './utils';
  
  // 格式化并显示时间
  function updateTimeDisplay() {
    document.querySelectorAll('.time-current').forEach(el => {
      const time = parseFloat(el.getAttribute('data-time') || '0');
      el.textContent = formatTime(time);
    });
    
    document.querySelectorAll('.time-duration').forEach(el => {
      const time = parseFloat(el.getAttribute('data-time') || '0');
      el.textContent = formatTime(time);
    });
  }
  
  // 初始化时间显示
  updateTimeDisplay();
  
  // 监听属性变化
  const observer = new MutationObserver(updateTimeDisplay);
  document.querySelectorAll('.time-current, .time-duration').forEach(el => {
    observer.observe(el, { attributes: true, attributeFilter: ['data-time'] });
  });
</script>

<style>
  .progress-bar-container {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    width: 100%;
  }
  
  .progress-bar-wrapper {
    position: relative;
    width: 100%;
    padding: 0.375rem 0;
    cursor: pointer;
    transition: padding 0.2s ease;
  }

  .progress-bar-wrapper:hover {
    padding: 0.5rem 0;
  }
  
  .progress-bar-track {
    position: relative;
    width: 100%;
    height: 3px;
    background: oklch(var(--bc) / 0.1);
    border-radius: 1.5px;
    overflow: visible;
    transition: all 0.2s ease;
  }

  .progress-bar-wrapper:hover .progress-bar-track {
    height: 4px;
    background: oklch(var(--bc) / 0.12);
  }
  
  .progress-bar-fill {
    position: relative;
    height: 100%;
    background: linear-gradient(90deg, oklch(var(--p)) 0%, oklch(var(--p) / 0.8) 100%);
    border-radius: 1.5px;
    transition: width 0.1s linear;
    box-shadow: 0 0 8px oklch(var(--p) / 0.3);
  }

  .progress-bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, oklch(var(--p) / 0.3) 100%);
    border-radius: 1.5px;
    animation: shimmer 2s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
  }
  
  .progress-bar-thumb {
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%) scale(0);
    width: 10px;
    height: 10px;
    background: oklch(var(--p));
    border-radius: 50%;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 6px oklch(var(--bc) / 0.3), 0 0 0 3px oklch(var(--p) / 0.2);
  }
  
  .progress-bar-wrapper:hover .progress-bar-thumb {
    transform: translateY(-50%) scale(1);
  }

  .progress-bar-wrapper:active .progress-bar-thumb {
    transform: translateY(-50%) scale(1.2);
  }
  
  .progress-bar-time {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6875rem;
    color: oklch(var(--bc) / 0.5);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }
  
  .time-separator {
    margin: 0 0.25rem;
    opacity: 0.5;
  }
  
  /* 响应式设计 */
  @media (max-width: 640px) {
    .progress-bar-time {
      font-size: 0.625rem;
    }

    .progress-bar-track {
      height: 4px;
    }

    .progress-bar-wrapper:hover .progress-bar-track {
      height: 5px;
    }
  }
</style>
