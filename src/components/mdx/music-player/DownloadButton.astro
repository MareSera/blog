---
/**
 * DownloadButton - 下载按钮组件
 * 触发浏览器下载音频文件
 */

export interface Props {
  src: string;
  filename?: string;
  className?: string;
}

const { 
  src, 
  filename,
  className = '' 
} = Astro.props;

// 从 src 中提取文件名（如果没有提供）
const defaultFilename = filename || src.split('/').pop() || 'audio.mp3';
---

<a
  href={src}
  download={defaultFilename}
  class={`download-button ${className}`}
  aria-label="下载音频文件"
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 20 20"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- 下载图标：向下箭头 + 底部横线 -->
    <path
      d="M10 3 L10 13 M10 13 L6 9 M10 13 L14 9"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <path
      d="M4 17 L16 17"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    />
  </svg>
  <span class="download-text">下载</span>
</a>

<style>
  .download-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    width: 1.5rem;
    height: 1.5rem;
    background: transparent;
    border: none;
    color: oklch(var(--bc) / 0.6);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 0.25rem;
    flex-shrink: 0;
  }
  
  .download-button:hover {
    background: oklch(var(--bc) / 0.06);
    color: oklch(var(--bc) / 0.85);
    transform: scale(1.1);
  }
  
  .download-button:active {
    transform: scale(0.95);
  }
  
  .download-button:focus-visible {
    outline: 2px solid oklch(var(--p));
    outline-offset: 2px;
  }
  
  .download-button svg {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .download-button:hover svg {
    transform: scale(1.05);
  }
  
  .download-text {
    display: none;
  }
  
  /* 响应式设计 */
  @media (max-width: 640px) {
    .download-button {
      width: 1.5rem;
      height: 1.5rem;
    }
  }
</style>
