---
/**
 * MusicPlayerCard - 音乐播放器卡片主组件
 * 集成所有子组件，提供完整的音乐播放功能
 */

import type { MusicPlayerCardProps } from './music-player/types';
import PlayPauseButton from './music-player/PlayPauseButton.astro';
import ProgressBar from './music-player/ProgressBar.astro';
import VolumeControl from './music-player/VolumeControl.astro';
import DownloadButton from './music-player/DownloadButton.astro';

type Props = MusicPlayerCardProps;

const {
  src,
  title,
  artist,
  cover,
  defaultCover = '/img/tx.png',
  allowDownload = true,
  autoPlay = false,
  loop = false,
  preload = 'metadata',
  accentColor,
  className = '',
} = Astro.props;

// 生成唯一 ID
const playerId = `music-player-${Math.random().toString(36).substring(2, 11)}`;
---

<div 
  class={`music-player-card ${className}`}
  id={playerId}
  data-src={src}
  data-autoplay={autoPlay}
  data-loop={loop}
  data-preload={preload}
  style={accentColor ? `--accent-color: ${accentColor}` : undefined}
>
  <div class="music-player-content">
    <!-- 封面图片 -->
    <div class="music-player-cover">
      <img
        src={cover || defaultCover}
        alt={`${title} - ${artist}`}
        loading="lazy"
        onerror="this.onerror=null; this.src='/img/tx.png'"
      />
    </div>

    <!-- 音乐信息和控制 -->
    <div class="music-player-info">
      <!-- 歌曲信息和按钮 -->
      <div class="music-info-row">
        <div class="music-info">
          <h3 class="music-title">{title}</h3>
          <p class="music-artist">{artist}</p>
        </div>
        
        <div class="music-actions">
          <VolumeControl
            volume={0.8}
            isMuted={false}
          />
          
          {allowDownload && (
            <DownloadButton
              src={src}
              filename={`${artist} - ${title}.mp3`}
            />
          )}
        </div>
      </div>

      <!-- 播放控制 -->
      <div class="music-controls">
        <!-- 进度条 -->
        <div class="control-progress">
          <ProgressBar
            progress={0}
            currentTime={0}
            duration={0}
          />
        </div>
      </div>

      <!-- 加载和错误状态 -->
      <div class="music-status">
        <div class="status-loading" style="display: none;">
          <span class="loading-spinner"></span>
          <span>加载中...</span>
        </div>
        <div class="status-error" style="display: none;">
          <span class="error-icon">⚠️</span>
          <span class="error-message"></span>
        </div>
      </div>
    </div>

    <!-- 播放按钮 -->
    <div class="music-player-action">
      <PlayPauseButton 
        isPlaying={false}
        size={44}
      />
    </div>
  </div>
</div>

<script>
  import { AudioEngine } from './music-player/AudioEngine';
  import type { AudioState } from './music-player/types';

  // 存储已初始化的播放器实例
  const initializedPlayers = new Map<string, { engine: AudioEngine; cleanup: () => void }>();

  // 等待 DOM 加载完成
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayers);
  } else {
    initPlayers();
  }

  // 页面导航时清理所有播放器
  document.addEventListener('astro:before-preparation', cleanupAllPlayers);
  document.addEventListener('astro:page-load', initPlayers);

  function cleanupAllPlayers() {
    initializedPlayers.forEach(({ engine, cleanup }) => {
      cleanup();
      engine.destroy();
    });
    initializedPlayers.clear();
  }

  function initPlayers() {
    // 初始化所有音乐播放器
    document.querySelectorAll('.music-player-card').forEach((card) => {
      const playerId = card.id;
      const src = card.getAttribute('data-src');
      
      if (!src) {
        console.error('音乐播放器缺少 src 属性');
        return;
      }

      // 如果已经初始化过，跳过
      if (initializedPlayers.has(playerId)) {
        return;
      }

      console.log('初始化播放器:', playerId, 'src:', src);

      // 获取配置
      const autoPlay = card.getAttribute('data-autoplay') === 'true';
      const loop = card.getAttribute('data-loop') === 'true';
      const preload = card.getAttribute('data-preload') || 'metadata';

      // 创建音频引擎
      const engine = new AudioEngine(src, {
        autoPlay,
        loop,
        preload: 'auto', // 使用 auto 预加载以加快加载速度
        volume: 0.8,
      }, playerId);

      // 获取 DOM 元素
      const playButton = card.querySelector('.play-pause-button') as HTMLButtonElement;
      const progressBar = card.querySelector('.progress-bar-wrapper') as HTMLElement;
      const progressFill = card.querySelector('.progress-bar-fill') as HTMLElement;
      const timeCurrentEl = card.querySelector('.time-current') as HTMLElement;
      const timeDurationEl = card.querySelector('.time-duration') as HTMLElement;
      const volumeButton = card.querySelector('.volume-icon-button') as HTMLButtonElement;
      const volumeSlider = card.querySelector('.volume-slider') as HTMLInputElement;
      const statusLoading = card.querySelector('.status-loading') as HTMLElement;
      const statusError = card.querySelector('.status-error') as HTMLElement;
      const errorMessage = card.querySelector('.error-message') as HTMLElement;

    // 状态管理
    let state: AudioState = {
      isPlaying: false,
      currentTime: 0,
      duration: 0,
      progress: 0,
      volume: 0.8,
      isMuted: false,
      isLoading: true,
      error: null,
    };

    // 更新 UI
    function updateUI() {
      // 更新卡片播放状态类
      if (state.isPlaying) {
        card.classList.add('playing');
      } else {
        card.classList.remove('playing');
      }

      // 更新播放按钮
      const svg = playButton?.querySelector('svg');
      if (svg) {
        if (state.isPlaying) {
          playButton?.classList.add('playing');
          svg.innerHTML = `
            <rect x="14" y="12" width="6" height="24" fill="currentColor" rx="1" />
            <rect x="28" y="12" width="6" height="24" fill="currentColor" rx="1" />
          `;
        } else {
          playButton?.classList.remove('playing');
          svg.innerHTML = `<path d="M16 12 L16 36 L36 24 Z" fill="currentColor" />`;
        }
      }

      // 更新进度条
      if (progressFill) {
        progressFill.style.width = `${state.progress}%`;
      }
      if (timeCurrentEl) {
        timeCurrentEl.setAttribute('data-time', state.currentTime.toString());
      }
      if (timeDurationEl) {
        timeDurationEl.setAttribute('data-time', state.duration.toString());
      }

      // 更新音量图标
      const volumeSvg = volumeButton?.querySelector('svg');
      if (volumeSvg) {
        if (state.isMuted || state.volume === 0) {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <line x1="23" y1="9" x2="17" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <line x1="17" y1="9" x2="23" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        } else if (state.volume < 0.5) {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <path d="M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        } else {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <path d="M15.54 8.46a5 5 0 010 7.07M19.07 4.93a10 10 0 010 14.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        }
      }

      // 更新音量滑块
      if (volumeSlider) {
        volumeSlider.value = (state.volume * 100).toString();
      }

      // 更新状态显示
      if (statusLoading) {
        statusLoading.style.display = state.isLoading ? 'flex' : 'none';
      }
      if (statusError) {
        statusError.style.display = state.error ? 'flex' : 'none';
        if (state.error && errorMessage) {
          errorMessage.textContent = state.error.message;
        }
      }
    }

    // 播放/暂停
    const handlePlayClick = async () => {
      try {
        console.log('播放按钮被点击，当前状态:', state.isPlaying);
        if (state.isPlaying) {
          engine.pause();
          console.log('暂停播放');
        } else {
          await engine.play();
          console.log('开始播放');
        }
        state.isPlaying = engine.isPlaying();
        updateUI();
      } catch (error) {
        console.error('播放失败:', error);
        state.error = {
          type: 'LOAD_FAILED',
          message: '播放失败，请重试',
        };
        updateUI();
      }
    };

    // 进度条点击跳转
    const handleProgressClick = (e: MouseEvent) => {
      const rect = progressBar.getBoundingClientRect();
      const percent = (e.clientX - rect.left) / rect.width;
      const time = percent * state.duration;
      engine.seek(time);
    };

    // 进度条拖动功能
    let isDragging = false;

    const handleProgressDragStart = (e: MouseEvent) => {
      isDragging = true;
      document.body.style.userSelect = 'none';
      progressBar?.classList.add('dragging');
    };

    const handleProgressDragMove = (e: MouseEvent) => {
      if (!isDragging || !progressBar) return;
      
      const rect = progressBar.getBoundingClientRect();
      const percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      const time = percent * state.duration;
      
      // 更新 UI 显示
      state.currentTime = time;
      state.progress = percent * 100;
      updateUI();
    };

    const handleProgressDragEnd = (e: MouseEvent) => {
      if (!isDragging || !progressBar) return;
      
      const rect = progressBar.getBoundingClientRect();
      const percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      const time = percent * state.duration;
      
      engine.seek(time);
      isDragging = false;
      document.body.style.userSelect = '';
      progressBar?.classList.remove('dragging');
    };

    // 音量控制
    const handleVolumeClick = () => {
      if (state.isMuted) {
        engine.unmute();
        state.isMuted = false;
        state.volume = engine.getVolume();
      } else {
        engine.mute();
        state.isMuted = true;
        state.volume = 0;
      }
      updateUI();
    };

    const handleVolumeInput = (e: Event) => {
      const value = parseInt((e.target as HTMLInputElement).value) / 100;
      engine.setVolume(value);
      state.volume = value;
      state.isMuted = value === 0;
      updateUI();
    };

    playButton?.addEventListener('click', handlePlayClick);
    progressBar?.addEventListener('click', handleProgressClick);
    progressBar?.addEventListener('mousedown', handleProgressDragStart);
    document.addEventListener('mousemove', handleProgressDragMove);
    document.addEventListener('mouseup', handleProgressDragEnd);
    volumeButton?.addEventListener('click', handleVolumeClick);
    volumeSlider?.addEventListener('input', handleVolumeInput);

    // 监听音频事件
    engine.onTimeUpdate((time) => {
      state.currentTime = time;
      state.progress = engine.getProgress();
      updateUI();
    });

    engine.onLoadedMetadata(() => {
      state.duration = engine.getDuration();
      state.isLoading = false;
      updateUI();
    });

    engine.onEnded(() => {
      state.isPlaying = false;
      updateUI();
    });

    engine.onError((error) => {
      state.error = {
        type: 'LOAD_FAILED',
        message: error.message || '加载失败',
      };
      state.isLoading = false;
      updateUI();
    });

    // 初始化 UI
    updateUI();

    // 清理函数
    const cleanup = () => {
      playButton?.removeEventListener('click', handlePlayClick);
      progressBar?.removeEventListener('click', handleProgressClick);
      progressBar?.removeEventListener('mousedown', handleProgressDragStart);
      document.removeEventListener('mousemove', handleProgressDragMove);
      document.removeEventListener('mouseup', handleProgressDragEnd);
      volumeButton?.removeEventListener('click', handleVolumeClick);
      volumeSlider?.removeEventListener('input', handleVolumeInput);
    };

    // 存储实例和清理函数
    initializedPlayers.set(playerId, { engine, cleanup });
  });
  }

  // 窗口关闭时清理
  window.addEventListener('beforeunload', cleanupAllPlayers);
</script>

<style>
  .music-player-card {
    --accent-color: oklch(var(--p));
    width: 100%;
    max-width: 100%;
    margin: 1.25rem 0;
    padding: 0;
    background: oklch(var(--b1));
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px oklch(var(--bc) / 0.08);
    color: oklch(var(--bc));
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.08);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: slideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .music-player-card:hover {
    box-shadow: 0 4px 16px oklch(var(--bc) / 0.1);
  }

  .music-player-content {
    display: flex;
    gap: 0;
    align-items: stretch;
    height: 110px;
  }

  .music-player-cover {
    flex-shrink: 0;
    width: 110px;
    height: 110px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .music-player-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .music-player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.625rem 0.75rem;
    min-width: 0;
    justify-content: space-between;
  }

  .music-player-action {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.875rem;
  }

  .music-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .music-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .music-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .music-title {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
    color: oklch(var(--bc) / 0.9);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .music-artist {
    margin: 0;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: oklch(var(--bc) / 0.5);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .music-controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .control-progress {
    width: 100%;
  }

  .control-progress .progress-bar-wrapper.dragging {
    cursor: grabbing;
  }

  .control-progress .progress-bar-wrapper.dragging .progress-bar-thumb {
    transform: translateY(-50%) scale(1.3) !important;
  }

  .control-bottom {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.625rem;
  }

  .music-status {
    min-height: 0.75rem;
  }

  .status-loading,
  .status-error {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6875rem;
    color: oklch(var(--bc) / 0.6);
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .loading-spinner {
    display: inline-block;
    width: 0.625rem;
    height: 0.625rem;
    border: 2px solid oklch(var(--bc) / 0.2);
    border-top-color: var(--accent-color);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .status-error {
    color: oklch(var(--er));
  }

  /* 播放动画效果 */
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
  }

  .music-player-card.playing .music-player-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, oklch(var(--p) / 0.15) 0%, transparent 70%);
    animation: pulse 2s ease-in-out infinite;
    z-index: 1;
  }

  /* 响应式设计 */
  @media (max-width: 640px) {
    .music-player-card {
      margin: 1rem 0;
    }

    .music-player-content {
      flex-direction: column;
      height: auto;
    }

    .music-player-cover {
      width: 100%;
      height: 140px;
    }

    .music-player-info {
      padding: 0.875rem;
    }

    .music-player-action {
      padding: 0.875rem;
      border-top: 1px solid oklch(var(--bc) / 0.08);
    }

    .music-info {
      text-align: center;
      margin-bottom: 0.5rem;
    }

    .control-main {
      justify-content: center;
    }

    .music-title {
      font-size: 0.9375rem;
    }

    .music-artist {
      font-size: 0.6875rem;
    }
  }
</style>
