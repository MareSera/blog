---
/**
 * MusicPlayerCard - 音乐播放器卡片主组件
 * 集成所有子组件，提供完整的音乐播放功能
 */

import type { MusicPlayerCardProps } from './music-player/types';
import PlayPauseButton from './music-player/PlayPauseButton.astro';
import ProgressBar from './music-player/ProgressBar.astro';
import VolumeControl from './music-player/VolumeControl.astro';
import DownloadButton from './music-player/DownloadButton.astro';

type Props = MusicPlayerCardProps;

const {
  src,
  title,
  artist,
  cover,
  defaultCover = '/img/tx.png',
  allowDownload = true,
  autoPlay = false,
  loop = false,
  preload = 'metadata',
  accentColor,
  className = '',
} = Astro.props;

// 生成唯一 ID
const playerId = `music-player-${Math.random().toString(36).substring(2, 11)}`;
---

<div 
  class={`music-player-card ${className}`}
  id={playerId}
  data-src={src}
  data-autoplay={autoPlay}
  data-loop={loop}
  data-preload={preload}
  style={accentColor ? `--accent-color: ${accentColor}` : undefined}
>
  <div class="music-player-content">
    <!-- 封面图片 -->
    <div class="music-player-cover">
      <img
        src={cover || defaultCover}
        alt={`${title} - ${artist}`}
        loading="lazy"
        onerror="this.onerror=null; this.src='/img/tx.png'"
      />
    </div>

    <!-- 音乐信息和控制 -->
    <div class="music-player-info">
      <!-- 歌曲信息 -->
      <div class="music-info">
        <h3 class="music-title">{title}</h3>
        <p class="music-artist">{artist}</p>
      </div>

      <!-- 播放控制 -->
      <div class="music-controls">
        <div class="control-main">
          <PlayPauseButton 
            isPlaying={false}
            size={48}
          />
        </div>

        <!-- 进度条 -->
        <div class="control-progress">
          <ProgressBar
            progress={0}
            currentTime={0}
            duration={0}
          />
        </div>

        <!-- 底部控制栏 -->
        <div class="control-bottom">
          <VolumeControl
            volume={0.8}
            isMuted={false}
          />
          
          {allowDownload && (
            <DownloadButton
              src={src}
              filename={`${artist} - ${title}.mp3`}
            />
          )}
        </div>
      </div>

      <!-- 加载和错误状态 -->
      <div class="music-status">
        <div class="status-loading" style="display: none;">
          <span class="loading-spinner"></span>
          <span>加载中...</span>
        </div>
        <div class="status-error" style="display: none;">
          <span class="error-icon">⚠️</span>
          <span class="error-message"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { AudioEngine } from './music-player/AudioEngine';
  import type { AudioState } from './music-player/types';

  // 等待 DOM 加载完成
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayers);
  } else {
    initPlayers();
  }

  function initPlayers() {
    // 初始化所有音乐播放器
    document.querySelectorAll('.music-player-card').forEach((card) => {
      const playerId = card.id;
      const src = card.getAttribute('data-src');
      
      if (!src) {
        console.error('音乐播放器缺少 src 属性');
        return;
      }

      console.log('初始化播放器:', playerId, 'src:', src);

      // 获取配置
      const autoPlay = card.getAttribute('data-autoplay') === 'true';
      const loop = card.getAttribute('data-loop') === 'true';
      const preload = card.getAttribute('data-preload') || 'metadata';

      // 创建音频引擎
      const engine = new AudioEngine(src, {
        autoPlay,
        loop,
        preload: preload as 'none' | 'metadata' | 'auto',
        volume: 0.8,
      }, playerId);

      // 获取 DOM 元素
      const playButton = card.querySelector('.play-pause-button') as HTMLButtonElement;
      const progressBar = card.querySelector('.progress-bar-wrapper') as HTMLElement;
      const progressFill = card.querySelector('.progress-bar-fill') as HTMLElement;
      const timeCurrentEl = card.querySelector('.time-current') as HTMLElement;
      const timeDurationEl = card.querySelector('.time-duration') as HTMLElement;
      const volumeButton = card.querySelector('.volume-icon-button') as HTMLButtonElement;
      const volumeSlider = card.querySelector('.volume-slider') as HTMLInputElement;
      const statusLoading = card.querySelector('.status-loading') as HTMLElement;
      const statusError = card.querySelector('.status-error') as HTMLElement;
      const errorMessage = card.querySelector('.error-message') as HTMLElement;

    // 状态管理
    let state: AudioState = {
      isPlaying: false,
      currentTime: 0,
      duration: 0,
      progress: 0,
      volume: 0.8,
      isMuted: false,
      isLoading: true,
      error: null,
    };

    // 更新 UI
    function updateUI() {
      // 更新播放按钮
      const svg = playButton?.querySelector('svg');
      if (svg) {
        if (state.isPlaying) {
          svg.innerHTML = `
            <rect x="14" y="12" width="6" height="24" fill="currentColor" rx="1" />
            <rect x="28" y="12" width="6" height="24" fill="currentColor" rx="1" />
          `;
        } else {
          svg.innerHTML = `<path d="M16 12 L16 36 L36 24 Z" fill="currentColor" />`;
        }
      }

      // 更新进度条
      if (progressFill) {
        progressFill.style.width = `${state.progress}%`;
      }
      if (timeCurrentEl) {
        timeCurrentEl.setAttribute('data-time', state.currentTime.toString());
      }
      if (timeDurationEl) {
        timeDurationEl.setAttribute('data-time', state.duration.toString());
      }

      // 更新音量图标
      const volumeSvg = volumeButton?.querySelector('svg');
      if (volumeSvg) {
        if (state.isMuted || state.volume === 0) {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <line x1="23" y1="9" x2="17" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <line x1="17" y1="9" x2="23" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        } else if (state.volume < 0.5) {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <path d="M15.54 8.46a5 5 0 010 7.07" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        } else {
          volumeSvg.innerHTML = `
            <path d="M11 5L6 9H2v6h4l5 4V5z" fill="currentColor" />
            <path d="M15.54 8.46a5 5 0 010 7.07M19.07 4.93a10 10 0 010 14.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          `;
        }
      }

      // 更新音量滑块
      if (volumeSlider) {
        volumeSlider.value = (state.volume * 100).toString();
      }

      // 更新状态显示
      if (statusLoading) {
        statusLoading.style.display = state.isLoading ? 'flex' : 'none';
      }
      if (statusError) {
        statusError.style.display = state.error ? 'flex' : 'none';
        if (state.error && errorMessage) {
          errorMessage.textContent = state.error.message;
        }
      }
    }

    // 播放/暂停
    playButton?.addEventListener('click', async () => {
      try {
        console.log('播放按钮被点击，当前状态:', state.isPlaying);
        if (state.isPlaying) {
          engine.pause();
          console.log('暂停播放');
        } else {
          await engine.play();
          console.log('开始播放');
        }
        state.isPlaying = engine.isPlaying();
        updateUI();
      } catch (error) {
        console.error('播放失败:', error);
        state.error = {
          type: 'LOAD_FAILED',
          message: '播放失败，请重试',
        };
        updateUI();
      }
    });

    // 进度条点击跳转
    progressBar?.addEventListener('click', (e) => {
      const rect = progressBar.getBoundingClientRect();
      const percent = (e.clientX - rect.left) / rect.width;
      const time = percent * state.duration;
      engine.seek(time);
    });

    // 音量控制
    volumeButton?.addEventListener('click', () => {
      if (state.isMuted) {
        engine.unmute();
        state.isMuted = false;
        state.volume = engine.getVolume();
      } else {
        engine.mute();
        state.isMuted = true;
        state.volume = 0;
      }
      updateUI();
    });

    volumeSlider?.addEventListener('input', (e) => {
      const value = parseInt((e.target as HTMLInputElement).value) / 100;
      engine.setVolume(value);
      state.volume = value;
      state.isMuted = value === 0;
      updateUI();
    });

    // 监听音频事件
    engine.onTimeUpdate((time) => {
      state.currentTime = time;
      state.progress = engine.getProgress();
      updateUI();
    });

    engine.onLoadedMetadata(() => {
      state.duration = engine.getDuration();
      state.isLoading = false;
      updateUI();
    });

    engine.onEnded(() => {
      state.isPlaying = false;
      updateUI();
    });

    engine.onError((error) => {
      state.error = {
        type: 'LOAD_FAILED',
        message: error.message || '加载失败',
      };
      state.isLoading = false;
      updateUI();
    });

    // 初始化 UI
    updateUI();

    // 清理
    window.addEventListener('beforeunload', () => {
      engine.destroy();
    });
  });
  }
</script>

<style>
  .music-player-card {
    --accent-color: oklch(var(--p));
    width: 100%;
    max-width: 100%;
    margin: 2rem 0;
    padding: 0;
    background: oklch(var(--b1));
    border-radius: 1rem;
    box-shadow: 0 4px 12px oklch(var(--bc) / 0.1);
    color: oklch(var(--bc));
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.1);
  }

  .music-player-content {
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  .music-player-cover {
    flex-shrink: 0;
    width: 180px;
    height: 180px;
    overflow: hidden;
    position: relative;
  }

  .music-player-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .music-player-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    min-width: 0;
    justify-content: space-between;
  }

  .music-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .music-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: oklch(var(--bc));
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .music-artist {
    margin: 0;
    font-size: 0.875rem;
    color: oklch(var(--bc) / 0.6);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .music-controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .control-main {
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .control-progress {
    width: 100%;
  }

  .control-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .music-status {
    min-height: 1.5rem;
  }

  .status-loading,
  .status-error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: oklch(var(--bc) / 0.6);
  }

  .loading-spinner {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    border: 2px solid oklch(var(--bc) / 0.2);
    border-top-color: var(--accent-color);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .status-error {
    color: oklch(var(--er));
  }

  /* 响应式设计 */
  @media (max-width: 640px) {
    .music-player-card {
      margin: 1.5rem 0;
    }

    .music-player-content {
      flex-direction: column;
    }

    .music-player-cover {
      width: 100%;
      height: 200px;
    }

    .music-player-info {
      padding: 1.25rem;
    }

    .music-info {
      text-align: center;
    }

    .control-main {
      justify-content: center;
    }
  }
</style>
