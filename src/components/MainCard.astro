---
import { t } from "@config";
import { Icon } from "astro-icon/components";
import Card from "@/components/temple/Card.astro";
import { Image } from "astro:assets";
import type { PostData } from "@interfaces/data";

export interface MainCardProps extends PostData {
  infoIcon?: string; // Icon for the info button
  helpText?: string; // Custom help text (defaults to "Learn More")
  textOverlay?: string; // Text to overlay on background when no image
  showTextBackground?: boolean; // Show text background when no image
  headerClass?: string; // Additional classes for the header
  extraClasses?: string; // Additional classes for the whole card
}

const {
  title,
  description,
  image,
  infoIcon = "lucide:help-circle",
  helpText = t("label.learnMore"),
  textOverlay,
  showTextBackground = true,
  headerClass = "",
  extraClasses = "",
} = Astro.props as MainCardProps;

// Create a more descriptive label for the button
const accessibleHelpText = `${helpText}: ${title}`;
---

<Card class={`overflow-hidden main-card-enhanced ${extraClasses}`}>
  {
    image ? (
      // With image - show image with overlay title
      <div class="relative group/header">
        <div class="aspect-[21/9] md:aspect-[21/7] w-full overflow-hidden">
          <!-- Gradient overlay for better text readability -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent z-10"></div>
          <!-- Decorative gradient accent -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary via-secondary to-accent z-20"></div>
          <Image
            src={image}
            alt={title}
            width={1200}
            height={630}
            format="webp"
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover transition-transform duration-700 group-hover/header:scale-105"
          />
        </div>

        {/* Flex container for Title and Button */}
        <div class="absolute bottom-4 left-4 right-4 lg:bottom-6 lg:left-6 lg:right-6 flex items-end justify-between gap-4 z-20">
          {/* Title */}
          <div class="inline-block bg-base-100/95 backdrop-blur-md px-6 py-3 rounded-2xl border-2 border-base-content/20 shadow-2xl transform transition-all duration-500 hover:scale-105 hover:border-base-content/30">
            <h1 class="text-xl sm:text-2xl lg:text-4xl font-bold text-base-content drop-shadow-lg">{title}</h1>
          </div>

          {/* Description Button */}
          {description && (
            <div class="flex-shrink-0">
              <div class="dropdown dropdown-top dropdown-end dropdown-hover">
                <label
                  tabindex="0"
                  aria-label={accessibleHelpText}
                  class="group btn btn-sm px-2 bg-base-100/95 backdrop-blur-md hover:bg-base-200 border-2 border-base-content/20 hover:border-base-content/30 text-base-content shadow-2xl rounded-full flex items-center gap-0 transition-all duration-300 ease-in-out hover:scale-110"
                >
                  <Icon name={infoIcon} class="w-4 h-4 flex-shrink-0" />
                  <span class="w-0 overflow-hidden group-hover:w-20 transition-all duration-300 text-xs whitespace-nowrap">
                    {helpText}
                  </span>
                </label>
                <div
                  tabindex="0"
                  class="dropdown-content z-[1] card w-64 sm:w-80 p-2 shadow-2xl bg-base-100/95 backdrop-blur-md text-base-content border-2 border-base-content/20 mb-4 rounded-2xl"
                  data-state="closed"
                >
                  <div class="card-body p-4">
                    <p class="text-sm leading-relaxed">{description}</p>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    ) : textOverlay ? (
      // No image, but with textOverlay - show gradient background with overlay text
      <div class="relative group/header">
        <div class={`aspect-[21/9] md:aspect-[21/7] w-full overflow-hidden bg-gradient-to-br from-base-200 via-base-300 to-base-200 border-b-2 border-base-content/10 ${headerClass}`}>
          <!-- Decorative gradient accent -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-base-content/30 via-base-content/20 to-base-content/30 z-20"></div>
          {showTextBackground && textOverlay && (
            <div class="absolute inset-0 w-full h-full error-animation-container">
              <div class="text-overlay-animated text-7xl md:text-9xl font-bold absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 transition-all duration-700 group-hover/header:scale-110">
                {textOverlay}
              </div>
            </div>
          )}
        </div>

        {/* Flex container for Title and Button */}
        <div class="absolute bottom-4 left-4 right-4 lg:bottom-6 lg:left-6 lg:right-6 flex items-end justify-between gap-4 z-20">
          {/* Title */}
          <div class="inline-block bg-base-100/95 backdrop-blur-md px-6 py-3 rounded-2xl border-2 border-base-content/20 shadow-2xl transform transition-all duration-500 hover:scale-105 hover:border-base-content/30">
            <h1 class="text-xl sm:text-2xl lg:text-4xl font-bold text-base-content drop-shadow-lg">{title}</h1>
          </div>

          {/* Description Button */}
          {description && (
            <div class="flex-shrink-0">
              <div class="dropdown dropdown-top dropdown-end dropdown-hover">
                <label
                  tabindex="0"
                  aria-label={accessibleHelpText}
                  class="group btn btn-sm px-2 bg-base-100/95 backdrop-blur-md hover:bg-base-200 border-2 border-base-content/20 hover:border-base-content/30 text-base-content shadow-2xl rounded-full flex items-center gap-0 transition-all duration-300 ease-in-out hover:scale-110"
                >
                  <Icon name={infoIcon} class="w-4 h-4 flex-shrink-0" />
                  <span class="w-0 overflow-hidden group-hover:w-20 transition-all duration-300 text-xs whitespace-nowrap">
                    {helpText}
                  </span>
                </label>
                <div
                  tabindex="0"
                  class="dropdown-content z-[1] card w-64 sm:w-80 p-2 shadow-2xl bg-base-100/95 backdrop-blur-md text-base-content border-2 border-base-content/20 mb-4 rounded-2xl"
                  data-state="closed"
                >
                  <div class="card-body p-4">
                    <p class="text-sm leading-relaxed">{description}</p>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    ) : (
      // No image, no textOverlay - show simple title and description at top
      <div class="pt-6 px-6 relative">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-base-content/30 via-base-content/20 to-base-content/30"></div>
        <h1 class="text-xl sm:text-2xl lg:text-4xl font-bold text-base-content">{title}</h1>
        {description && <p class="mt-2 text-sm text-base-content/80">{description}</p>}
      </div>
    )
  }

  <!-- Content section -->
  <div class="p-4 sm:p-6 bg-base-100">
    <slot />
  </div>
</Card>

<script>
  document.addEventListener("astro:page-load", () => {
    // Get all info buttons and dropdown contents
    const infoButtons = document.querySelectorAll(".dropdown label");
    const dropdownContents = document.querySelectorAll(".dropdown-content");

    // Add click event listeners
    infoButtons.forEach((button, index) => {
      button.addEventListener("click", () => {
        const content = dropdownContents[index];
        const currentState = content.getAttribute("data-state");

        // Toggle state
        if (currentState === "closed") {
          content.setAttribute("data-state", "open");
          // Add animation classes when opening
          content.classList.add("scale-100", "opacity-100");
          content.classList.remove("scale-90", "opacity-0");
        } else {
          content.setAttribute("data-state", "closed");
          // Remove animation classes when closing
          content.classList.add("scale-90", "opacity-0");
          content.classList.remove("scale-100", "opacity-100");
        }
      });
    });

    // Trigger text overlay animation on page load
    const textOverlays = document.querySelectorAll(".text-overlay-animated");
    textOverlays.forEach((overlay) => {
      // Remove animation class first
      overlay.classList.remove("text-overlay-enter");
      // Force reflow
      void (overlay as HTMLElement).offsetWidth;
      // Add animation class
      overlay.classList.add("text-overlay-enter");
    });
  });
</script>

<style>
  /* Title popup animation - like a message notification */
  @keyframes titlePopup {
    0% {
      opacity: 0;
      transform: scale(0.8) translateY(20px);
    }
    50% {
      transform: scale(1.05) translateY(-5px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Text overlay entrance animation */
  @keyframes textOverlayEnter {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.92) translateY(12px);
      filter: blur(8px);
    }
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1) translateY(0);
      filter: blur(0px);
    }
  }

  /* Apply animation to all title boxes */
  .inline-block.bg-gradient-to-br {
    animation: titlePopup 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }

  /* Apply animation to text overlay */
  .text-overlay-animated.text-overlay-enter {
    animation: textOverlayEnter 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  /* Permanent text overlay styling */
  .text-overlay-animated {
    color: oklch(var(--bc) / 0.3) !important;
    text-shadow: 0 0 40px oklch(var(--bc) / 0.3), 0 0 20px oklch(var(--bc) / 0.2) !important;
    -webkit-text-stroke: 1px oklch(var(--bc) / 0.15) !important;
  }

  .group\/header:hover .text-overlay-animated {
    color: oklch(var(--bc) / 0.5) !important;
  }
  
  /* Shimmer effect on hover */
  .main-card-enhanced::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: left 0.7s ease;
    pointer-events: none;
  }
  
  .main-card-enhanced:hover::after {
    left: 100%;
  }
</style>
