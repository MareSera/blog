---
// Magnetic cursor
---

<div class="mag-pointer" id="mag-pointer" aria-hidden="true">
  <div></div><div></div><div></div><div></div>
</div>

<style is:global>
  /* 仅在非触摸设备上隐藏默认光标 */
  html:not(.mag-cursor-disabled) *, 
  html:not(.mag-cursor-disabled) *::before, 
  html:not(.mag-cursor-disabled) *::after { cursor: none !important; }

  .mag-pointer {
    --mp-color: oklch(var(--bc));
    position: fixed;
    top: 0; left: 0;
    width: 0; height: 0;
    pointer-events: none;
    z-index: 99999;
    opacity: 0;
    will-change: transform;
  }
  .mag-pointer div {
    position: absolute;
    width: 0.7rem; height: 0.7rem;
    border-width: 0.18rem;
    border-color: var(--mp-color);
  }
  .mag-pointer div:nth-child(1) { top:0;    left:0;  border-top-style:solid;    border-left-style:solid;  }
  .mag-pointer div:nth-child(2) { top:0;    right:0; border-top-style:solid;    border-right-style:solid; }
  .mag-pointer div:nth-child(3) { bottom:0; left:0;  border-bottom-style:solid; border-left-style:solid;  }
  .mag-pointer div:nth-child(4) { bottom:0; right:0; border-bottom-style:solid; border-right-style:solid; }

  /* 禁用自定义光标时恢复默认 */
  .mag-cursor-disabled *, .mag-cursor-disabled *::before, .mag-cursor-disabled *::after {
    cursor: auto !important;
  }
  .mag-cursor-disabled .mag-pointer {
    display: none !important;
  }
</style>

<script is:inline>
(function () {
  // 触摸设备或不支持 RAF 时跳过
  if ('ontouchstart' in window || !window.requestAnimationFrame) {
    document.documentElement.classList.add('mag-cursor-disabled');
    return;
  }

  // prefers-reduced-motion 时跳过
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.documentElement.classList.add('mag-cursor-disabled');
    return;
  }

  var DEFAULT_SIZE = 38.4;
  var POS_SPEED    = 0.14;
  var SIZE_SPEED   = 0.06;
  var PAD_RATIO    = 50;
  var IDLE_TIMEOUT = 2000; // 2秒无移动则暂停 RAF
  var SELECTOR     = "a, button, [role='button'], input, textarea, select, label[for], .btn, .badge";

  var container;
  var mouseX = -9999, mouseY = -9999;
  var curX   = -9999, curY   = -9999;
  var curW   = DEFAULT_SIZE, curH = DEFAULT_SIZE;
  var targetW = DEFAULT_SIZE, targetH = DEFAULT_SIZE;
  var rafId = null;
  var visible = false;
  var lastMoveTime = 0;
  var isIdle = false;

  // 当前绑定的事件处理器引用（用于清理）
  var boundMouseMove = null;
  var boundDocLeave = null;

  function lerp(a, b, t) { return a + (b - a) * t; }

  function hitTarget(x, y) {
    var el = document.elementFromPoint(x, y);
    while (el && el !== document.body) {
      if (el.matches && el.matches(SELECTOR)) return el;
      el = el.parentElement;
    }
    return null;
  }

  function stopRAF() {
    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
  }

  function startRAF() {
    if (rafId === null) {
      rafId = requestAnimationFrame(tick);
    }
  }

  function tick() {
    // 检测空闲：超过 IDLE_TIMEOUT 毫秒无鼠标移动则暂停
    if (Date.now() - lastMoveTime > IDLE_TIMEOUT && visible) {
      isIdle = true;
      rafId = null;
      return; // 不再调度下一帧
    }

    var hit = hitTarget(mouseX, mouseY);

    var tX = mouseX, tY = mouseY;
    if (hit) {
      var r  = hit.getBoundingClientRect();
      var cx = r.left + r.width  / 2;
      var cy = r.top  + r.height / 2;
      tX = cx + (mouseX - cx) * 0.1;
      tY = cy + (mouseY - cy) * 0.1;
      var pad = window.innerWidth / PAD_RATIO;
      targetW = r.width  + pad;
      targetH = r.height + pad;
    } else {
      targetW = DEFAULT_SIZE;
      targetH = DEFAULT_SIZE;
    }

    curX = lerp(curX, tX, POS_SPEED);
    curY = lerp(curY, tY, POS_SPEED);
    curW = lerp(curW, targetW, SIZE_SPEED);
    curH = lerp(curH, targetH, SIZE_SPEED);

    container.style.transform = "translate(" + (curX - curW / 2) + "px," + (curY - curH / 2) + "px)";
    container.style.width  = curW + "px";
    container.style.height = curH + "px";

    rafId = requestAnimationFrame(tick);
  }

  function onMouseMove(e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
    lastMoveTime = Date.now();

    if (!visible) {
      curX = mouseX; curY = mouseY;
      container.style.opacity = "1";
      visible = true;
    }

    // 若处于空闲状态，重新启动 RAF
    if (isIdle) {
      isIdle = false;
      startRAF();
    }
  }

  function onDocLeave() {
    container.style.opacity = "0";
    visible = false;
  }

  function cleanup() {
    stopRAF();
    if (boundMouseMove) {
      window.removeEventListener("mousemove", boundMouseMove);
      boundMouseMove = null;
    }
    if (boundDocLeave) {
      document.documentElement.removeEventListener("mouseleave", boundDocLeave);
      boundDocLeave = null;
    }
  }

  function init() {
    // 每次初始化都重新检测触摸设备
    if ('ontouchstart' in window || !window.requestAnimationFrame) {
      document.documentElement.classList.add('mag-cursor-disabled');
      return;
    }
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('mag-cursor-disabled');
      return;
    }

    container = document.getElementById("mag-pointer");
    if (!container) return;

    // 清理旧监听器，防止 View Transitions 导致重复绑定
    cleanup();

    // 重置状态
    visible = false;
    isIdle = false;
    lastMoveTime = Date.now();

    boundMouseMove = onMouseMove;
    boundDocLeave = onDocLeave;

    window.addEventListener("mousemove", boundMouseMove);
    document.documentElement.addEventListener("mouseleave", boundDocLeave);

    startRAF();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  // View Transitions：每次页面加载后重新初始化
  document.addEventListener("astro:page-load", function () {
    init();
  });
})();
</script>
