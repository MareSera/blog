---
import { SITE_MENU, USER_AVATAR, USER_SIDEBAR_SOCIAL_ICONS } from "../../config";
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
import { Image } from "astro:assets";

// Get current path to determine active link
const currentPath = Astro.url.pathname;
---

<Card class="profile-card-enhanced">
  <div class="relative p-6 flex flex-col">
    <!-- Avatar with minimal styling -->
    <div class="flex justify-center mb-6">
      <div class="avatar-wrapper relative group">
        <Image
          class="mask mask-circle relative z-10 ring-2 ring-base-content/5 group-hover:ring-base-content/15 transition-all duration-300 transform group-hover:scale-[1.02]"
          format="webp"
          width={250}
          height={250}
          src={USER_AVATAR}
          alt="Profile"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>

    <!-- Menu with minimal design -->
    <ul class="menu bg-transparent w-full m-0 p-0 hidden md:flex flex-col items-center lg:items-start space-y-1">
      {
        SITE_MENU.map((item) => (
          <li class="w-full">
            {item.subItems ? (
              <details class="menu-item w-full" data-submenu-id={item.id} open={currentPath.startsWith(item.href)}>
                <summary class="justify-center lg:justify-start items-center text-xl md:text-3xl lg:text-lg font-medium p-3 hover:bg-base-content/5 rounded-lg transition-all duration-200 cursor-pointer">
                  <Icon name={item.svg} class="w-5 h-5" />
                  <span class="hidden lg:inline ml-3">{item.text}</span>
                </summary>
                <ul class="rounded-lg mt-1 space-y-0.5 ml-2">
                  {item.subItems.map((subItem) => (
                    <li>
                      <a
                        tabindex="0"
                        class="menu-item text-base md:text-2xl lg:text-sm font-normal p-2.5 pl-8 hover:bg-base-content/5 rounded-lg transition-all duration-200"
                        id={`header-${subItem.id}`}
                        href={subItem.href}
                        target={subItem.target || "_self"}
                        aria-label={subItem.text}
                      >
                        <Icon name={subItem.svg} class="w-4 h-4" />
                        <span class="hidden lg:inline ml-2">{subItem.text}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a
                tabindex="0"
                class="flex justify-center lg:justify-start items-center text-xl md:text-3xl lg:text-lg font-medium p-3 hover:bg-base-content/5 rounded-lg transition-all duration-200"
                id={item.id}
                href={item.href}
                target={item.target || "_self"}
                aria-label={item.text}
              >
                <Icon name={item.svg} class="w-5 h-5" />
                <span class="hidden lg:inline ml-3">{item.text}</span>
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <!-- Social Icons with minimal styling -->
    <div class="mt-6 pt-6 border-t border-base-content/5">
      <div class="grid grid-cols-4 md:grid-cols-2 lg:grid-cols-4 gap-2 justify-items-center">
        {
          USER_SIDEBAR_SOCIAL_ICONS.map((icon) => (
            <div class="tooltip tooltip-bottom" data-tip={icon.title}>
              <a
                tabindex="0"
                href={icon.href}
                aria-label={icon.ariaLabel}
                target="_blank"
                class="btn btn-sm btn-circle btn-ghost hover:bg-base-content/5 transition-all duration-200"
              >
                <Icon name={icon.svg} class="text-lg" />
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Card>

<style>
  .avatar-wrapper {
    width: fit-content;
  }

  .profile-card-enhanced {
    background: oklch(var(--b1));
    border: 1px solid oklch(var(--bc) / 0.05);
  }

  /* Active menu item indicator */
  .menu-item[aria-current="page"] {
    background: oklch(var(--bc) / 0.05);
    font-weight: 500;
  }
</style>
