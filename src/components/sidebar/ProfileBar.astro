---
import { SITE_MENU, USER_AVATAR, USER_SIDEBAR_SOCIAL_ICONS } from "../../config";
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
import { Image } from "astro:assets";

// Get current path to determine active link
const currentPath = Astro.url.pathname;
---

<Card class="profile-card-enhanced">
  <div class="relative p-6 flex flex-col">
    <!-- Avatar with enhanced styling -->
    <div class="p-2 flex justify-center mb-4">
      <div class="avatar-wrapper relative group">
        <div class="absolute inset-0 bg-gradient-to-br from-primary via-secondary to-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl"></div>
        <Image
          class="mask mask-circle relative z-10 ring-4 ring-base-200 group-hover:ring-primary/50 transition-all duration-500 transform group-hover:scale-105"
          format="webp"
          width={250}
          height={250}
          src={USER_AVATAR}
          alt="Profile"
          loading="eager"
        />
      </div>
    </div>

    <!-- Menu -->
    <ul class="menu bg-transparent w-full m-0 p-0 hidden md:flex flex-col items-center lg:items-start space-y-1">
      {
        SITE_MENU.map((item) => (
          <li class="w-full relative group/item">
            {item.subItems ? (
              <details class="menu-item w-full" data-submenu-id={item.id} open={currentPath.startsWith(item.href)}>
                <summary class="justify-center lg:justify-start items-center text-center text-xl md:text-3xl lg:text-xl font-bold p-4 hover:bg-gradient-to-r hover:from-primary/10 hover:to-secondary/10 rounded-xl transition-all duration-300 cursor-pointer group-hover/item:translate-x-1">
                  <Icon name={item.svg} class="group-hover/item:scale-110 group-hover/item:text-primary transition-all duration-300" />
                  <span class="hidden lg:inline ml-2 group-hover/item:text-primary transition-colors duration-300">{item.text}</span>
                </summary>
                <ul class="rounded-xl mt-1 space-y-1">
                  {item.subItems.map((subItem) => (
                    <li class="relative">
                      <a
                        tabindex="0"
                        class="menu-item text-base md:text-2xl lg:text-base font-bold p-3 hover:bg-gradient-to-r hover:from-secondary/10 hover:to-accent/10 rounded-lg transition-all duration-300 hover:translate-x-2"
                        id={`header-${subItem.id}`}
                        href={subItem.href}
                        target={subItem.target || "_self"}
                        aria-label={subItem.text}
                      >
                        <Icon name={subItem.svg} class="hover:scale-110 hover:text-secondary transition-all duration-300" />
                        <span class="hidden lg:inline ml-2">{subItem.text}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a
                tabindex="0"
                class="flex justify-center lg:justify-start items-center text-center text-xl md:text-3xl lg:text-xl font-bold p-4 hover:bg-gradient-to-r hover:from-primary/10 hover:to-secondary/10 rounded-xl transition-all duration-300 group-hover/item:translate-x-1"
                id={item.id}
                href={item.href}
                target={item.target || "_self"}
                aria-label={item.text}
              >
                <Icon name={item.svg} class="group-hover/item:scale-110 group-hover/item:text-primary transition-all duration-300" />
                <span class="hidden lg:inline ml-2 group-hover/item:text-primary transition-colors duration-300">{item.text}</span>
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <!-- Social Icons with enhanced styling -->
    <div class="mt-6 pt-4 border-t border-base-content/10">
      <div class="grid grid-cols-4 md:grid-cols-2 lg:grid-cols-4 gap-2 justify-items-center">
        {
          USER_SIDEBAR_SOCIAL_ICONS.map((icon) => (
            <div class="tooltip tooltip-bottom" data-tip={icon.title}>
              <a
                tabindex="0"
                href={icon.href}
                aria-label={icon.ariaLabel}
                target="_blank"
                class="btn btn-circle btn-ghost hover:bg-gradient-to-br hover:from-primary/20 hover:to-secondary/20 hover:scale-110 transition-all duration-300 group"
              >
                <Icon name={icon.svg} class="text-xl group-hover:scale-125 group-hover:text-primary transition-all duration-300" />
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Card>

<style>
  .avatar-wrapper {
    width: fit-content;
  }

  .profile-card-enhanced {
    background: linear-gradient(135deg, oklch(var(--b1)) 0%, oklch(var(--b2) / 0.5) 100%);
  }

  /* Active menu item indicator */
  .menu-item[aria-current="page"] {
    background: oklch(var(--b2));
    border-left: 3px solid oklch(var(--bc) / 0.3);
  }
</style>
