---
import BaseLayout from "@layouts/BaseLayout.astro";
import { t } from "@config";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";

Astro.response.status = 404;
const pathname = Astro.url.pathname;

let title: string;
let description: string;
let textOverlay: string;
let primaryAction: { href: string; text: string; icon: string };

if (pathname.startsWith("/blog/tag/")) {
  const attemptedValue = decodeURIComponent(pathname.split("/")[3] || "");
  title = `${t("label.tagPage")} "${attemptedValue}" ${t("label.notFound")}`;
  description = t("label.tagNotFoundDescription");
  textOverlay = "404";
  primaryAction = {
    href: "/blog/tags",
    text: t("label.allTags"),
    icon: "lucide:tags",
  };
} else if (pathname.startsWith("/blog/category/")) {
  const attemptedValue = decodeURIComponent(pathname.split("/")[3] || "");
  title = `${t("label.categoryPage")} "${attemptedValue}" ${t("label.notFound")}`;
  description = t("label.categoryNotFoundDescription");
  textOverlay = "404";
  primaryAction = {
    href: "/blog/categories",
    text: t("label.allCategories"),
    icon: "lucide:folders",
  };
} else {
  title = t("label.404title");
  description = t("label.404description");
  textOverlay = "404";
  primaryAction = {
    href: "/",
    text: t("label.404backHome"),
    icon: "lucide:home",
  };
}
---

<BaseLayout title={title} isIndexed={false}>
  <MainCard title={title} description={description} textOverlay={textOverlay} infoIcon="lucide:help-circle">
    <!-- 主要提示信息 -->
    <div class="text-center my-8 error-main-box">
      <div class="inline-block p-8 bg-base-200/50 rounded-2xl border border-base-content/10 mb-6 shadow-lg backdrop-blur-sm">
        <div class="error-icon-wrapper">
          <Icon name="lucide:search-x" class="w-20 h-20 mx-auto text-error mb-4 animate-bounce-slow" />
        </div>
        <p class="error-title text-2xl font-bold mb-3">{title}</p>
        <p class="error-subtitle text-base opacity-70 mb-6">{description}</p>
      </div>
    </div>

    <!-- 操作按钮 -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center my-8 error-buttons">
      <a href={primaryAction.href} class="btn btn-primary gap-2 btn-shine-effect">
        <Icon name={primaryAction.icon} class="w-5 h-5" />
        <span>{primaryAction.text}</span>
      </a>
      <button id="goBackBtn" class="btn btn-outline gap-2" onclick="history.back()">
        <Icon name="lucide:corner-up-left" class="w-5 h-5" />
        <span>{t("label.404goBack")}</span>
      </button>
    </div>

    <div class="divider my-6 error-divider">
      <Icon name="lucide:map" class="w-10 h-10 opacity-50" />
    </div>

    <!-- 推荐内容 -->
    <div class="text-center mb-6 error-heading">
      <h3 class="text-xl font-bold mb-4">{t("您可以浏览以下内容") || "您可以浏览以下内容"}</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/blog" class="error-card card bg-base-200/50 p-6 hover-lift text-center transition-all duration-300 group border border-base-content/10" data-index="0">
        <div class="text-primary mb-3 group-hover:scale-110 transition-transform duration-300">
          <Icon name="lucide:book-open" class="w-10 h-10 mx-auto" />
        </div>
        <h3 class="font-semibold text-lg mb-2">{t("label.404exploreBlog")}</h3>
        <p class="text-sm opacity-70">{t("label.404exploreBlogDesc") || "阅读最新文章"}</p>
      </a>

      <a href="/blog/archives" class="error-card card bg-base-200/50 p-6 hover-lift text-center transition-all duration-300 group border border-base-content/10" data-index="1">
        <div class="text-secondary mb-3 group-hover:scale-110 transition-transform duration-300">
          <Icon name="lucide:archive" class="w-10 h-10 mx-auto" />
        </div>
        <h3 class="font-semibold text-lg mb-2">{t("label.404browseArchives")}</h3>
        <p class="text-sm opacity-70">{t("label.404browseArchivesDesc") || "按时间浏览"}</p>
      </a>

      <a href="/blog/search" class="error-card card bg-base-200/50 p-6 hover-lift text-center transition-all duration-300 group border border-base-content/10" data-index="2">
        <div class="text-accent mb-3 group-hover:scale-110 transition-transform duration-300">
          <Icon name="lucide:search" class="w-10 h-10 mx-auto" />
        </div>
        <h3 class="font-semibold text-lg mb-2">{t("label.404searchContent")}</h3>
        <p class="text-sm opacity-70">{t("label.404searchContentDesc") || "搜索您想要的内容"}</p>
      </a>
    </div>
  </MainCard>
</BaseLayout>

<style>
  /* 主框淡入缩放动画 */
  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.9) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .error-main-box {
    animation: fadeInScale 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  /* 图标旋转淡入 */
  @keyframes iconRotateIn {
    from {
      opacity: 0;
      transform: rotate(-180deg) scale(0.5);
    }
    to {
      opacity: 1;
      transform: rotate(0deg) scale(1);
    }
  }

  .error-icon-wrapper {
    animation: iconRotateIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }

  /* 标题淡入 */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .error-title {
    animation: fadeIn 0.6s ease-out 0.5s both;
  }

  .error-subtitle {
    animation: fadeIn 0.6s ease-out 0.7s both;
  }

  /* 按钮弹入 */
  @keyframes bounceIn {
    0% {
      opacity: 0;
      transform: scale(0.3) translateY(20px);
    }
    50% {
      transform: scale(1.05) translateY(-5px);
    }
    70% {
      transform: scale(0.95) translateY(0);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .error-buttons {
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.9s both;
  }

  /* 分隔线展开 */
  @keyframes expandWidth {
    from {
      opacity: 0;
      transform: scaleX(0);
    }
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  .error-divider {
    animation: expandWidth 0.8s ease-out 1.2s both;
  }

  /* 标题淡入 */
  .error-heading {
    animation: fadeIn 0.6s ease-out 1.4s both;
  }

  /* 卡片级联淡入 */
  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .error-card {
    opacity: 0;
    animation: cardFadeIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .error-card[data-index="0"] {
    animation-delay: 1.6s;
  }

  .error-card[data-index="1"] {
    animation-delay: 1.75s;
  }

  .error-card[data-index="2"] {
    animation-delay: 1.9s;
  }

  /* 悬停上浮效果 */
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hover-lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px -6px oklch(var(--bc) / 0.2);
  }

  /* 按钮光泽效果 */
  .btn-shine-effect {
    position: relative;
    overflow: hidden;
  }

  .btn-shine-effect::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s ease;
  }

  .btn-shine-effect:hover::before {
    left: 100%;
  }

  /* 慢速弹跳动画 */
  @keyframes bounceSlow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  .animate-bounce-slow {
    animation: bounceSlow 2.5s ease-in-out infinite;
  }
</style>
