---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import EssayCard from "@/components/mdx/EssayCard.astro";

// 示例随笔数据 - 你可以后续从文件或数据库中读取
const essays = [
  {
    date: "2024-03-15",
    content: "今天读了一本很有趣的书，关于时间管理的。书中提到，真正的效率不是做更多的事，而是做正确的事。这让我想起了最近的工作状态，总是忙忙碌碌却不知道在忙什么。或许，我们都需要停下来思考一下，什么才是真正重要的。",
    image: "/image/image1.jpg",
  },
  {
    date: "2024-03-10",
    content: "春天来了，窗外的樱花开得正盛。每年这个时候都会想起很多往事，那些美好的、遗憾的，都随着花瓣一起飘落。人生就像这樱花，短暂而绚烂。",
  },
  {
    date: "2024-03-05",
    content: "最近在学习新的编程语言，发现学习的过程本身就是一种享受。从陌生到熟悉，从困惑到豁然开朗，这种感觉真的很棒。编程不仅是一门技术，更是一种思维方式。它教会我们如何分解问题，如何寻找解决方案，如何在复杂中找到简洁。",
    image: "/image/image2.jpg",
  },
  {
    date: "2024-02-28",
    content: "今天和朋友聊天，谈到了梦想这个话题。我们都曾有过很多梦想，但随着年龄的增长，有些梦想渐渐淡去了。不过，只要心中还有火焰，就永远不算太晚。",
  },
  {
    date: "2024-02-20",
    content: "深夜写代码的时候，突然想到一个问题：我们为什么要写博客？是为了记录生活，还是为了分享知识？或许两者都有，但更重要的是，这是一种与自己对话的方式。通过文字，我们可以更清晰地看到自己的思考轨迹，也能在未来的某一天，回顾今天的自己。",
    image: "/image/image3.png",
  },
  {
    date: "2024-02-15",
    content: "看了一部很感人的电影，讲述的是关于家庭和亲情的故事。有时候我们总是忽略身边最重要的人，把时间都花在了其他地方。珍惜当下，珍惜身边的人。",
  },
  {
    date: "2024-02-10",
    content: "今天尝试了一个新的咖啡店，环境很安静，适合思考和写作。点了一杯拿铁，坐在窗边看着来来往往的行人。每个人都有自己的故事，每个人都在为生活奔波。",
  },
  {
    date: "2024-02-05",
    content: "最近在思考一个问题：什么是成功？是金钱、地位，还是内心的平静？我想，真正的成功应该是做自己喜欢的事，和喜欢的人在一起，过自己想要的生活。",
    image: "/image/image4.jpg",
  },
];
---

<BaseLayout title="随笔">
  <MainCard
    title="随笔"
    description="记录生活中的点点滴滴，分享一些随想和感悟。"
    textOverlay="ESSAY"
    infoIcon="material-symbols:ink-pen-outline-rounded"
  >
    <div class="space-y-8">
      <!-- Header Section with enhanced styling -->
      <section class="text-center py-6 animate-fade-in">
        <div class="inline-flex items-center gap-4 mb-4">
          <div class="h-1 w-32 md:w-48 bg-gradient-to-r from-transparent via-primary to-primary animate-expand-left"></div>
          <Icon name="material-symbols:ink-pen-outline-rounded" class="w-20 h-20 md:w-32 md:h-32 text-primary" />
          <div class="h-1 w-32 md:w-48 bg-gradient-to-l from-transparent via-primary to-primary animate-expand-right"></div>
        </div>
        <p class="text-base-content/80 max-w-2xl mx-auto text-lg leading-relaxed animate-slide-up">
          生活不止眼前的苟且，还有诗和远方。<br />
          <span class="text-sm text-base-content/60">这里记录着我的思考、感悟和日常</span>
        </p>
      </section>

      <!-- Stats Section -->
      <section class="grid grid-cols-3 gap-4 max-w-2xl mx-auto animate-fade-in-up">
        <div class="text-center p-4 bg-base-200/30 rounded-xl border border-base-200/50 hover:scale-105 transition-transform animate-stat-item" style="animation-delay: 0.1s;">
          <div class="text-2xl font-bold text-primary">{essays.length}</div>
          <div class="text-xs text-base-content/60 mt-1">篇随笔</div>
        </div>
        <div class="text-center p-4 bg-base-200/30 rounded-xl border border-base-200/50 hover:scale-105 transition-transform animate-stat-item" style="animation-delay: 0.2s;">
          <div class="text-2xl font-bold text-secondary">{essays.filter((e) => e.image).length}</div>
          <div class="text-xs text-base-content/60 mt-1">张配图</div>
        </div>
        <div class="text-center p-4 bg-base-200/30 rounded-xl border border-base-200/50 hover:scale-105 transition-transform animate-stat-item" style="animation-delay: 0.3s;">
          <div class="text-2xl font-bold text-accent">
            {essays.reduce((sum, e) => sum + e.content.length, 0)}
          </div>
          <div class="text-xs text-base-content/60 mt-1">字记录</div>
        </div>
      </section>

      <!-- Masonry Grid for Essays with improved spacing -->
      <section class="essay-container">
        <div class="columns-1 md:columns-2 gap-6">
          {essays.map((essay) => <EssayCard date={essay.date} content={essay.content} image={essay.image} />)}
        </div>
      </section>

      <!-- Decorative divider -->
      <div class="divider my-10">
        <div class="flex items-center gap-2">
          <Icon name="lucide:sparkles" class="w-5 h-5 text-primary/60" />
          <Icon name="material-symbols:ink-pen-outline-rounded" class="w-8 h-8 text-primary" />
          <Icon name="lucide:sparkles" class="w-5 h-5 text-primary/60" />
        </div>
      </div>

      <!-- Call to action with enhanced styling -->
      <div class="text-center bg-gradient-to-br from-base-200/30 to-base-300/30 rounded-2xl p-8 border border-base-200/50">
        <Icon name="lucide:book-heart" class="w-12 h-12 text-primary mx-auto mb-4" />
        <p class="text-base-content/80 mb-6 text-lg">更多随笔正在路上...</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/blog" class="btn btn-primary gap-2 shadow-lg hover:shadow-xl transition-shadow">
            <Icon name="lucide:book-open" class="w-5 h-5" />
            <span>查看博客文章</span>
          </a>
          <a href="/" class="btn btn-outline btn-primary gap-2">
            <Icon name="lucide:home" class="w-5 h-5" />
            <span>返回首页</span>
          </a>
        </div>
      </div>
    </div>
  </MainCard>
</BaseLayout>

<style>
  .essay-container {
    position: relative;
  }

  /* Smooth column layout */
  .columns-1,
  .md\:columns-2 {
    column-gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .md\:columns-2 {
      column-gap: 1.5rem;
    }
  }

  /* Ensure consistent spacing */
  :global(.essay-card-wrapper) {
    margin-bottom: 1.5rem;
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes expandLeft {
    from {
      opacity: 0;
      width: 0;
    }
    to {
      opacity: 1;
      width: 100%;
    }
  }

  @keyframes expandRight {
    from {
      opacity: 0;
      width: 0;
    }
    to {
      opacity: 1;
      width: 100%;
    }
  }

  @keyframes bounceSlow {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-8px) scale(1);
    }
  }

  @keyframes statItem {
    from {
      opacity: 0;
      transform: scale(0.8) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out 0.2s both;
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }

  .animate-slide-up {
    animation: slideUp 0.6s ease-out 0.3s both;
  }

  .animate-expand-left {
    animation: expandLeft 0.6s ease-out 0.2s both;
  }

  .animate-expand-right {
    animation: expandRight 0.6s ease-out 0.2s both;
  }

  .animate-bounce-slow {
    animation: bounceSlow 2s ease-in-out infinite;
  }

  .animate-stat-item {
    animation: statItem 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
</style>
