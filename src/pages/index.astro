---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
---

<BaseLayout title="Home">
  <MainCard
    title="Welcome！"
    description="一个简单的小站点，表达态度，表达观点，表达自己"
    textOverlay="HOME"
    infoIcon="lucide:info"
  >
    <div class="space-y-10">
      <!-- Hero Section -->
      <section class="py-8 animate-section">
        <div class="flex flex-col items-center text-center">
          <!-- Animated Title -->
          <div class="mb-6 relative animate-item" style="animation-delay: 0.1s;">
            <div class="absolute inset-0 blur-2xl opacity-30 bg-base-content/10 animate-pulse-slow"></div>
            <h1
              class="text-4xl md:text-5xl font-bold text-base-content relative"
              style="line-height: 1.6; padding-bottom: 0.5rem; display: inline-block;"
            >
              🌟 MareSera's Blog
            </h1>
          </div>

          <!-- Subtitle with decoration -->
          <div class="mb-8 relative animate-item" style="animation-delay: 0.2s;">
            <div class="absolute -top-2 left-1/2 transform -translate-x-1/2 w-48 md:w-64 h-1 bg-gradient-to-r from-transparent via-base-content/30 to-transparent animate-expand-horizontal"></div>
            <p class="text-xl md:text-2xl text-base-content/80 max-w-3xl mt-4">
              一个高中生的小站！来看看我的态度！
            </p>
          </div>

          <!-- Poetry Section with enhanced styling -->
          <div class="mb-10 relative max-w-2xl animate-item" style="animation-delay: 0.35s;">
            <div class="absolute -left-4 top-0 bottom-0 w-1 bg-gradient-to-b from-base-content/30 via-base-content/20 to-base-content/10 rounded-full animate-slide-down"></div>
            <div class="bg-gradient-to-br from-base-200/40 to-base-300/40 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-base-200/50 shadow-lg hover:shadow-xl transition-shadow duration-300">
              <Icon name="lucide:quote" class="w-8 h-8 text-base-content/40 mb-3 animate-float" />
              <p
                class="text-base md:text-lg font-medium text-base-content leading-relaxed text-left"
              >
                敏感的人心里住的是春天，
                所以他们流泪时，<br />
                滴落的是花瓣，是晨露，
                是草坪泥土的气息<br />
                是所有的柔软的事物<br />
                ——唯独不是软弱<br />
                如今只愿岁月停留，生怕走得太急
              </p>
              <div class="flex justify-end mt-4">
                <Icon name="lucide:sparkles" class="w-5 h-5 text-base-content/60 animate-twinkle" />
              </div>
            </div>
          </div>


          <!-- Action Buttons with enhanced styling -->
          <div class="flex flex-wrap gap-4 justify-center">
            <a
              href="/blog"
              class="btn gap-2 shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 group animate-item"
              style="animation-delay: 0.5s;"
            >
              <Icon name="lucide:book-open" class="w-5 h-5 group-hover:rotate-12 transition-transform" />
              <span>查看文章</span>
            </a>
            <a
              href="https://poems.maresera.top/"
              class="btn gap-2 shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 group animate-item"
              style="animation-delay: 0.6s;"
            >
              <Icon name="material-symbols:ink-pen-outline-rounded" class="w-5 h-5 group-hover:rotate-12 transition-transform" />
              <span>我的诗集</span>
            </a>
            <a
              href="https://github.com/MareSera/"
              target="_blank"
              class="btn btn-outline gap-2 hover:shadow-lg transition-all duration-300 hover:scale-105 group animate-item"
              style="animation-delay: 0.7s;"
            >
              <Icon name="lucide:github" class="w-5 h-5 group-hover:rotate-12 transition-transform" />
              <span>我的Github</span>
            </a>
            <a
              href="https://qm.qq.com/q/ftDkUQzd9S"
              target="_blank"
              class="btn btn-outline gap-2 hover:shadow-lg transition-all duration-300 hover:scale-105 group animate-item"
              style="animation-delay: 0.8s;"
            >
              <Icon name="ri:cup-line" class="w-5 h-5 group-hover:rotate-12 transition-transform" />
              <span>交流QQ群</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Decorative Divider -->
      <div class="divider my-8 animate-item" style="animation-delay: 0.8s;">
        <div class="flex items-center gap-2">
          <Icon name="lucide:sparkles" class="w-5 h-5 text-base-content/60 animate-pulse" />
          <Icon name="lucide:code-2" class="w-6 h-6 text-base-content" />
          <Icon name="lucide:sparkles" class="w-5 h-5 text-base-content/60 animate-pulse" />
        </div>
      </div>

      <!-- GitHub Stats Section with enhanced styling -->
      <section class="py-6 animate-section" style="animation-delay: 0.9s;">
        <div class="flex items-center justify-between mb-6 flex-wrap gap-4 animate-item">
          <div class="flex items-center gap-3">
            <div class="bg-base-200 rounded-full p-3 shadow-md hover:scale-110 transition-transform">
              <Icon name="lucide:github" class="w-6 h-6 text-base-content" />
            </div>
            <h2 class="text-2xl md:text-3xl font-bold">Repository Stats</h2>
          </div>
          <a
            href="https://github.com/MareSera/LogicLyric"
            target="_blank"
            class="btn btn-sm btn-outline gap-2 group hover:scale-105 transition-transform"
          >
            <span>访问仓库</span>
            <Icon name="lucide:external-link" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>

        <div class="bg-gradient-to-br from-base-200/30 to-base-300/30 rounded-2xl p-6 border border-base-200/50 shadow-lg hover:shadow-xl transition-shadow duration-300 animate-item" style="animation-delay: 0.1s;">
          <GitHubStats username="MareSera" repositoryName="LogicLyric" showLanguages={true} showContributors={true} />
        </div>
      </section>

      <!-- Quick Links Section -->
      <section class="py-6 animate-section" style="animation-delay: 1s;">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 animate-item">
          <Icon name="lucide:compass" class="w-6 h-6 text-base-content" />
          <span>快速导航</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a
            href="/about"
            class="card bg-gradient-to-br from-base-100 to-base-200/50 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-base-200/50 group animate-item"
            style="animation-delay: 0.1s;"
          >
            <div class="card-body p-6">
              <div class="flex items-center gap-3 mb-2">
                <div class="bg-base-200 rounded-full p-2 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
                  <Icon name="lucide:user" class="w-5 h-5 text-base-content" />
                </div>
                <h3 class="card-title text-lg">关于我</h3>
              </div>
              <p class="text-sm text-base-content/70">了解更多关于我的信息</p>
            </div>
          </a>

          <a
            href="/project"
            class="card bg-gradient-to-br from-base-100 to-base-200/50 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-base-200/50 group animate-item"
            style="animation-delay: 0.2s;"
          >
            <div class="card-body p-6">
              <div class="flex items-center gap-3 mb-2">
                <div class="bg-base-200 rounded-full p-2 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
                  <Icon name="lucide:folder-code" class="w-5 h-5 text-base-content" />
                </div>
                <h3 class="card-title text-lg">我的项目</h3>
              </div>
              <p class="text-sm text-base-content/70">查看我的开源项目</p>
            </div>
          </a>

          <a
            href="/friend"
            class="card bg-gradient-to-br from-base-100 to-base-200/50 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-base-200/50 group animate-item"
            style="animation-delay: 0.3s;"
          >
            <div class="card-body p-6">
              <div class="flex items-center gap-3 mb-2">
                <div class="bg-base-200 rounded-full p-2 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
                  <Icon name="lucide:users" class="w-5 h-5 text-base-content" />
                </div>
                <h3 class="card-title text-lg">友情链接</h3>
              </div>
              <p class="text-sm text-base-content/70">我的朋友们和资源</p>
            </div>
          </a>
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>

<style>
  /* Base animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      height: 0;
    }
    to {
      opacity: 1;
      height: 100%;
    }
  }

  @keyframes expandHorizontal {
    from {
      opacity: 0;
      width: 0;
    }
    to {
      opacity: 1;
      width: 100%;
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes twinkle {
    0%, 100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  @keyframes pulseSlow {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Apply animations */
  .animate-item {
    animation: fadeInUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .animate-section {
    animation: fadeInUp 0.8s ease-out both;
  }

  .animate-slide-down {
    animation: slideDown 0.8s ease-out 0.3s both;
  }

  .animate-expand-horizontal {
    animation: expandHorizontal 0.8s ease-out 0.15s both;
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-twinkle {
    animation: twinkle 2s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulseSlow 3s ease-in-out infinite;
  }

  /* Hover effects */
  .card:hover {
    background: oklch(var(--b2));
  }

  /* Smooth transitions for all interactive elements */
  .btn, .card, a {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
