---
import BaseLayout from "@layouts/BaseLayout.astro";
import License from "@components/widgets/License.astro";
import PostInfo from "@components/widgets/PostInfo.astro";
import PostFilter from "@components/widgets/PostFilter.astro";
import { type CollectionEntry, getCollection } from "astro:content";
import dayjs from "@utils/dayjs";
import { DATE_FORMAT } from "@config";
import MainCard from "@/components/MainCard.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((blog: { slug: any }) => ({
    params: { slug: blog.slug },
    props: { blog },
  }));
}
interface Props {
  blog: CollectionEntry<"blog">;
}

const { blog } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await blog.render();
const displayDate = blog.data.pubDate ? dayjs(blog.data.pubDate).format(DATE_FORMAT) : "";
const url = new URL(`/${blog.slug}`, Astro.url.origin);
---

<BaseLayout title={blog.data.title} image={blog.data.image} headings={headings} showTOC={true}>
  <MainCard title={blog.data.title} description={blog.data.description} image={blog.data.image} infoIcon="lucide:info">
    <!-- Article metadata section with enhanced styling -->
    <div class="article-meta-section mb-8 pb-6 border-b border-base-content/10">
      <PostInfo
        pubDate={displayDate}
        badge={blog.data.badge}
        word={remarkPluginFrontmatter.totalCharCount}
        time={remarkPluginFrontmatter.readingTime}
      />

      <!-- Categories and tags -->
      <div class="mt-4">
        <PostFilter categories={blog.data.categories} tags={blog.data.tags} />
      </div>
    </div>

    <!-- Article Content with optimized reading container -->
    <div class="article-content-wrapper">
      <!-- 沉浸模式专用标题（正常模式下隐藏，封面图已有标题） -->
      <h1 class="immersive-title">{blog.data.title}</h1>
      <div id="content" class="prose prose-lg max-w-none prose-headings:scroll-mt-20 prose-img:rounded-xl prose-img:mx-auto mx-auto">
        <Content />
        <License
          url={url}
          title={blog.data.title}
          image={blog.data.image}
          pubDate={blog.data.pubDate}
          badge={blog.data.badge}
          categories={blog.data.categories}
          tags={blog.data.tags}
          word={remarkPluginFrontmatter.totalCharCount}
          time={remarkPluginFrontmatter.readingTime}
        />
      </div>
    </div>
  </MainCard>

  <!-- 沉浸式阅读按钮注入工具栏（保留占位，实际按钮在右下角） -->

  <!-- 沉浸式阅读进入按钮（固定右下角，与返回顶部联动） -->
  <button
    id="immersive-btn"
    aria-label="沉浸式阅读"
    title="沉浸式阅读"
    style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;"
    class="btn btn-circle btn-md bg-base-100 shadow-lg hover:scale-110"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/>
      <path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/>
    </svg>
  </button>

  <!-- 沉浸式阅读退出按钮（固定右下角，沉浸模式时显示） -->
  <button
    id="immersive-exit-btn"
    aria-label="退出沉浸式阅读"
    title="退出沉浸式阅读"
    style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;align-items:center;gap:0.5rem;padding:0.625rem 1.125rem;border-radius:9999px;border:1px solid oklch(var(--bc)/0.12);font-size:0.875rem;font-weight:500;cursor:pointer;backdrop-filter:blur(12px);"
    class="bg-base-100 shadow-lg text-base-content/80 hover:bg-base-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 3v3a2 2 0 0 1-2 2H3"/><path d="M21 8h-3a2 2 0 0 1-2-2V3"/>
      <path d="M3 16h3a2 2 0 0 1 2 2v3"/><path d="M16 21v-3a2 2 0 0 1 2-2h3"/>
    </svg>
    <span>退出沉浸</span>
  </button>
</BaseLayout>

<script is:inline>
(function () {
  var STORAGE_KEY = 'immersive-reading';
  var initialized = false;

  function enter() {
    var enterBtn = document.getElementById('immersive-btn');
    var exitBtn = document.getElementById('immersive-exit-btn');
    document.documentElement.classList.add('immersive');
    localStorage.setItem(STORAGE_KEY, '1');
    if (enterBtn) enterBtn.style.display = 'none';
    if (exitBtn) exitBtn.style.display = 'flex';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function exit() {
    var enterBtn = document.getElementById('immersive-btn');
    var exitBtn = document.getElementById('immersive-exit-btn');
    document.documentElement.classList.remove('immersive');
    localStorage.removeItem(STORAGE_KEY);
    if (exitBtn) exitBtn.style.display = 'none';
    if (enterBtn) {
      enterBtn.style.display = '';
      updateImmersiveBtnPosition();
    }
  }

  function updateImmersiveBtnPosition() {
    var immersiveBtn = document.getElementById('immersive-btn');
    var scrollTopBtn = document.getElementById('scroll-to-top');
    if (!immersiveBtn) return;
    if (document.documentElement.classList.contains('immersive')) {
      immersiveBtn.style.display = 'none';
      return;
    }
    immersiveBtn.style.display = '';
    if (scrollTopBtn && scrollTopBtn.classList.contains('visible')) {
      immersiveBtn.style.bottom = 'calc(1.5rem + 3rem + 0.75rem)';
    } else {
      immersiveBtn.style.bottom = '1.5rem';
    }
  }

  function init() {
    var btn = document.getElementById('immersive-btn');
    var exitBtn = document.getElementById('immersive-exit-btn');

    if (btn && !btn.dataset.immersiveBound) {
      btn.dataset.immersiveBound = '1';
      btn.addEventListener('click', enter);
    }

    if (exitBtn && !exitBtn.dataset.immersiveBound) {
      exitBtn.dataset.immersiveBound = '1';
      exitBtn.addEventListener('click', exit);
    }

    window.addEventListener('scroll', updateImmersiveBtnPosition);
    updateImmersiveBtnPosition();

    if (localStorage.getItem(STORAGE_KEY)) enter();
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
})();
</script>

<style>
  .article-meta-section {
    background: linear-gradient(135deg, oklch(var(--b2) / 0.3) 0%, transparent 100%);
    padding: 1.5rem;
    border-radius: 1rem;
    margin: -0.5rem -0.5rem 2rem -0.5rem;
  }

  .article-content-wrapper {
    /* Optimal reading width */
    max-width: 75ch;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* Focus mode - reduce distractions */
  @media (min-width: 1024px) {
    .article-content-wrapper {
      padding: 0 2rem;
    }
  }

  /* Smooth scroll behavior for anchor links */
  :global(html) {
    scroll-behavior: smooth;
  }

  /* Highlight target heading when navigating via TOC */
  :global(#content :target) {
    animation: highlight-heading 2s ease-out;
  }

  @keyframes highlight-heading {
    0% {
      background-color: oklch(var(--bc) / 0.1);
      padding: 0.5rem;
      margin: -0.5rem;
      border-radius: 0.5rem;
    }
    100% {
      background-color: transparent;
    }
  }

  /* ===== 沉浸式阅读 ===== */

  /* 进入按钮过渡动画 */
  #immersive-btn {
    transition: bottom 0.3s ease, transform 0.2s ease;
  }

  /* 退出按钮 hover */
  #immersive-exit-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 24px oklch(var(--bc) / 0.15);
  }

  /* 沉浸模式：隐藏侧边栏、导航栏、页脚 */
  :global(html.immersive) :global(aside),
  :global(html.immersive) :global(nav),
  :global(html.immersive) :global(footer),
  :global(html.immersive) :global(.mobile-toc) {
    display: none !important;
  }

  /* 沉浸模式：主内容区全宽 */
  :global(html.immersive) :global(main) {
    grid-column: 1 / -1 !important;
    max-width: 90ch;
    margin: 0 auto;
    padding-top: 2rem;
  }

  /* 沉浸模式：隐藏文章封面大图，保留内容 */
  :global(html.immersive) :global(.main-card-enhanced > div:first-child) {
    display: none;
  }

  /* 沉浸模式：内容区增加上边距，显示标题 */
  :global(html.immersive) :global(.main-card-enhanced .p-4),
  :global(html.immersive) :global(.main-card-enhanced .p-6) {
    padding-top: 2.5rem;
  }

  /* 沉浸模式：显示文章标题 */
  :global(html.immersive) :global(.immersive-title) {
    display: block !important;
  }

  /* 沉浸模式：加宽阅读区域 */
  :global(html.immersive) :global(main) {
    grid-column: 1 / -1 !important;
    max-width: 90ch;
    margin: 0 auto;
    padding-top: 2rem;
  }

  :global(html.immersive) .article-content-wrapper {
    max-width: 90ch;
  }

  /* 沉浸模式：背景更纯净 */
  :global(html.immersive) :global(body) {
    background: oklch(var(--b1));
  }

  /* 沉浸模式标题样式（默认隐藏） */
  .immersive-title {
    display: none;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    color: oklch(var(--bc));
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid oklch(var(--bc) / 0.08);
  }
</style>
