---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
---

<BaseLayout title="About">
  <MainCard
    title="About MareSera"
    description="开发者、开源爱好者，以及 LogicLyric 博客主题的创作者。"
    textOverlay="ABOUT"
    infoIcon="lucide:user"
  >
    <div class="space-y-12 mb-8">
      <!-- Profile Section -->
      <section class="flex flex-col md:flex-row gap-8 items-center md:items-start animate-fade-in">
        <div class="avatar group">
          <div
            class="w-32 h-32 md:w-40 md:h-40 rounded-xl ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden transition-all duration-300 group-hover:ring-4 group-hover:scale-105"
          >
            <img src="./profile.png" alt="MareSera" width="160" height="160" loading="eager" class="transition-transform duration-300 group-hover:scale-110" />
          </div>
        </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-bold mb-2 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">MareSera</h1>
          <p class="text-xl text-base-content/80 mb-4 flex items-center gap-2 justify-center md:justify-start">
            <Icon name="lucide:sparkles" class="w-5 h-5 text-primary animate-pulse" />
            Developer & Open-Source Enthusiast
          </p>

          <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-6">
            <a
              href="https://github.com/MareSera"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 hover:scale-105 transition-transform group"
            >
              <Icon name="lucide:github" class="w-4 h-4 group-hover:rotate-12 transition-transform" />
              <span>GitHub</span>
            </a>
            <a
              href="./114514"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-outline gap-2 hover:scale-105 transition-transform group"
            >
              <Icon name="lucide:twitter" class="w-4 h-4 group-hover:rotate-12 transition-transform" />
              <span>Twitter</span>
            </a>
            <a href="mailto:yt.zev.liu@gmail.com" class="btn btn-sm btn-outline gap-2 hover:scale-105 transition-transform group">
              <Icon name="lucide:mail" class="w-4 h-4 group-hover:rotate-12 transition-transform" />
              <span>Email</span>
            </a>
          </div>

          <div class="bg-gradient-to-br from-base-200/40 to-base-300/40 backdrop-blur-sm rounded-xl p-4 border border-base-200/50">
            <p class="text-base-content/80 leading-relaxed">
              Hi! 我是 MareSera，你也可以叫我Zev，一名充满热情的开发者，专注于打造优雅、响应式且高效的网页应用。我是 LogicLyric 博客主题的创作者，这是一个现代的 Astro 主题，专为内容创作者设计。我喜欢为开源项目贡献力量，并构建帮助他人创造美丽数字体验的工具。
            </p>
          </div>
        </div>
      </section>

      <!-- Divider -->
      <div class="divider animate-fade-in">
        <Icon name="lucide:sparkles" class="w-12 h-12 text-primary" />
      </div>

      <!-- GitHub Stats -->
      <section class="animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-gradient-to-br from-primary/20 to-secondary/20 rounded-full p-3 shadow-md">
            <Icon name="lucide:github" class="w-6 h-6 text-primary" />
          </div>
          <h2 class="text-2xl md:text-3xl font-bold">GitHub Statistics</h2>
        </div>

        <div class="bg-gradient-to-br from-base-200/30 to-base-300/30 rounded-2xl p-6 border border-base-200/50 shadow-lg hover:shadow-xl transition-shadow">
          <GitHubStats username="MareSera" showLanguages={false} showCommitGraph={true} />
        </div>
      </section>

      <!-- Tech Stack -->
      <section class="animate-fade-in-up" style="animation-delay: 0.3s;">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-gradient-to-br from-secondary/20 to-accent/20 rounded-full p-3 shadow-md">
            <Icon name="lucide:code-2" class="w-6 h-6 text-secondary" />
          </div>
          <h2 class="text-2xl md:text-3xl font-bold">Tech Stack</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {
            [
              { name: "Astro", icon: "simple-icons:astro", color: "oklch(0.5 0.2 300)" },
              { name: "JavaScript", icon: "simple-icons:javascript", color: "oklch(0.8 0.2 80)" },
              { name: "TypeScript", icon: "simple-icons:typescript", color: "oklch(0.6 0.2 250)" },
              { name: "React", icon: "simple-icons:react", color: "oklch(0.7 0.2 200)" },
              { name: "Node.js", icon: "simple-icons:nodedotjs", color: "oklch(0.7 0.2 140)" },
              { name: "TailwindCSS", icon: "simple-icons:tailwindcss", color: "oklch(0.6 0.2 220)" },
              { name: "HTML5", icon: "simple-icons:html5", color: "oklch(0.7 0.2 30)" },
              { name: "CSS3", icon: "simple-icons:css3", color: "oklch(0.7 0.2 220)" },
              { name: "Git", icon: "simple-icons:git", color: "oklch(0.7 0.2 30)" },
              { name: "C++", icon: "simple-icons:cplusplus", color: "oklch(0.6 0.2 240)" },
              { name: "C#", icon: "simple-icons:csharp", color: "oklch(0.6 0.2 160)" },
              { name: "Python", icon: "simple-icons:python", color: "oklch(0.7 0.2 250)" },
            ].map((tech, index) => (
              <div 
                class="tech-card flex flex-col items-center justify-center p-4 bg-gradient-to-br from-base-100 to-base-200/50 rounded-xl hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-base-200/50 group cursor-pointer"
                style={`animation-delay: ${index * 0.05}s;`}
              >
                <div class="text-3xl mb-2 group-hover:scale-110 transition-transform" style={`color: ${tech.color}`}>
                  <Icon name={tech.icon} class="w-10 h-10" />
                </div>
                <span class="text-sm font-medium">{tech.name}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Contribution Activity -->
      <section class="animate-fade-in-up" style="animation-delay: 0.4s;">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-gradient-to-br from-accent/20 to-primary/20 rounded-full p-3 shadow-md">
            <Icon name="lucide:activity" class="w-6 h-6 text-accent" />
          </div>
          <h2 class="text-2xl md:text-3xl font-bold">Recent Activity</h2>
        </div>

        <div class="bg-gradient-to-br from-base-200/30 to-base-300/30 rounded-2xl p-6 border border-base-200/50 shadow-lg">
          <div class="flex flex-col md:flex-row gap-8 md:gap-6">
            {
              [
                {
                  date: "January 2024",
                  title: "Open Source Contributions",
                  desc: "参与了多个开源项目，专注于UI美化",
                  icon: "lucide:git-pull-request",
                  color: "primary"
                },
                {
                  date: "March 2025",
                  title: "Initiated LogicLyric Project",
                  desc: "开始开发 Astro 的 LogicLyric 博客主题，重点关注现代设计原则。",
                  icon: "lucide:rocket",
                  color: "secondary"
                },
              ].map((item, i) => (
                <div class="activity-item flex-1 relative flex gap-4 p-4 bg-base-100 rounded-xl hover:shadow-md transition-all hover:-translate-y-1 border border-base-200/50" style={`animation-delay: ${i * 0.1}s;`}>
                  <div class="flex flex-col items-center flex-shrink-0">
                    <div class={`w-12 h-12 rounded-full bg-${item.color}/20 flex items-center justify-center border-2 border-${item.color}`}>
                      <Icon name={item.icon} class={`w-6 h-6 text-${item.color}`} />
                    </div>
                  </div>
                  <div class="flex-1">
                    <div class="text-sm text-base-content/60 mb-1 flex items-center gap-2">
                      <Icon name="lucide:calendar" class="w-3.5 h-3.5" />
                      {item.date}
                    </div>
                    <h3 class="text-lg font-bold mb-1">{item.title}</h3>
                    <p class="text-sm text-base-content/80">{item.desc}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

    </div>
  </MainCard>
</BaseLayout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out both;
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out both;
  }

  .tech-card {
    animation: fadeInUp 0.6s ease-out both;
  }

  .activity-item {
    animation: fadeInUp 0.6s ease-out both;
  }

  .fact-card {
    animation: fadeInUp 0.6s ease-out both;
  }
</style>
